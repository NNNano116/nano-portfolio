# ─────────────────────────────────────────────────────────────
# .env 템플릿 — 이 파일을 복사해 ".env" 로 만들고 값을 채우세요.
#   cp .env.example .env      (PowerShell: Copy-Item .env.example .env)
#
# ⚠️ ".env" 는 .gitignore 로 추적 제외됩니다. 절대 커밋하지 마세요.
# ⚠️ 이 값들은 "로컬 git/도구 인증용"입니다. 빌드 산출물(dist/)에 넣지 마세요
#    (정적 사이트는 클라이언트에 그대로 노출됩니다).
# ⚠️ GitHub Actions 의 비밀은 .env 가 아니라
#    저장소 Settings → Secrets and variables → Actions 에 등록합니다.
# 자세한 규약: docs/git-setup.md
# ─────────────────────────────────────────────────────────────

# git config 에 사용할 작성자 정보
GIT_USER_NAME=
GIT_USER_EMAIL=

# GitHub 계정
GITHUB_USERNAME=

# Personal Access Token (비밀)
#  - fine-grained 권장 / 대상 저장소 한정 / contents: write 최소 권한 / 만료일 설정
#  - gh CLI 는 GH_TOKEN 또는 GITHUB_TOKEN 환경변수를 인식합니다.
GITHUB_TOKEN=

# 원격 저장소 주소 (선택)
GIT_REMOTE_URL=
